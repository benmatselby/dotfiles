# Theme
#theme = Rose Pine Moon
theme = dark:Rose Pine Moon,light:Rose Pine Dawn

# Make alt work
macos-option-as-alt = true

# Some stylistic changes
window-padding-x = 10
window-padding-y = 10

# Set the ti
title = "Coding is life"

# Colourise the cursor
cursor-color = #ff69b4

# Start tmux by default
command = /opt/homebrew/bin/tmux new-session -A -s flow
